# Backend Environment Variables (Production Deployment)
# Copy this file to .env and fill in your actual values

# Stripe Secret Key (starts with sk_live_ or sk_test_)
# ⚠️ CRITICAL: NEVER expose this key in frontend code or commit to Git!
# Get this from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_secret_key_here

# Stripe Webhook Secret (starts with whsec_)
# Get this from: https://dashboard.stripe.com/webhooks
# Only needed if you set up webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Server Configuration
PORT=5000
NODE_ENV=production

# Frontend URL for CORS
# The domain(s) that are allowed to make requests to this API
FRONTEND_URL=https://ygiholidayhomes.com

# Alternative: Comma-separated list for multiple domains
# FRONTEND_URL=https://ygiholidayhomes.com,https://www.ygiholidayhomes.com
